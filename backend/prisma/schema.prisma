// RunTiming — schema dati (modular monolith). Derivato da run-timing-frontend/src/types.
// Le parti flessibili (formSchema, priceSteps, categorie, commissioni, template
// attestato, roster) sono Json; le entità portanti sono relazionali.

generator client {
  provider      = "prisma-client-js"
  // "native" per lo sviluppo locale, target musl per l'immagine Docker (alpine)
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ORGANIZER
  ATHLETE
  SOCIETY
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum CertStatus {
  NON_RICHIESTO
  IN_ATTESA
  VERIFICATO
  RIFIUTATO
}

model Account {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String
  role            Role
  displayName     String?
  assignedEventIds String[]       // eventi gestibili (organizer)
  createdAt       DateTime        @default(now())
  athlete         AthleteProfile?
  society         Society?
  createdEvents   Event[]         @relation("OrganizerEvents")
}

model AthleteProfile {
  id            String         @id @default(cuid())
  account       Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId     String         @unique
  nome          String
  cognome       String
  dataNascita   DateTime
  sesso         String
  codFiscale    String?        @unique
  phone         String?
  club          String?
  certType      String?
  certExpiry    DateTime?
  certStatus    CertStatus?
  affiliations  Affiliation[]
  registrations Registration[]
}

model Affiliation {
  id            String          @id @default(cuid())
  athlete       AthleteProfile? @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  athleteId     String?
  ente          String
  societaNome   String
  codiceSocieta String?
  numeroTessera String?
  certScadenza  DateTime?
  source        String?
}

model Society {
  id          String   @id @default(cuid())
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId   String   @unique
  societaNome String
  ente        String
  codiceFidal String?
  roster      Json     // RosterAthlete[]
  createdAt   DateTime @default(now())
}

model Event {
  id            String     @id @default(cuid())
  title         String
  slug          String     @unique
  category      String
  location      String
  city          String
  province      String
  lat           Float
  lng           Float
  coverImage    String?
  flyerUrl      String?
  regulationUrl String?
  description   String?
  isFeatured    Boolean    @default(false)
  isLive        Boolean    @default(false)
  organizer     String
  commission    Json?
  routeInfo     Json?
  createdBy     Account?   @relation("OrganizerEvents", fields: [createdById], references: [id])
  createdById   String?
  days          EventDay[]
  createdAt     DateTime   @default(now())
}

model EventDay {
  id      String   @id @default(cuid())
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String
  date    DateTime
  label   String?
  races   Race[]
}

model Race {
  id                  String         @id @default(cuid())
  day                 EventDay       @relation(fields: [dayId], references: [id], onDelete: Cascade)
  dayId               String
  name                String
  distance            String
  raceType            String
  ente                String?
  paymentMode         String?
  requiresMedicalCert Boolean        @default(false)
  minAge              Int?
  maxAge              Int?
  price               Float          @default(0)
  maxParticipants     Int            @default(0)
  isOpen              Boolean        @default(true)
  formSchema          Json?
  priceSteps          Json?
  publicFields        String[]
  publicColumns       String[]
  categories          Json?
  commission          Json?
  certificateTemplate Json?
  registrations       Registration[]
  resultRows          ResultRow[]
}

model DiscountCode {
  id          String    @id @default(cuid())
  code        String    @unique
  description String?
  type        String
  value       Float
  maxUses     Int?
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
}

model Registration {
  id               String          @id @default(cuid())
  race             Race            @relation(fields: [raceId], references: [id], onDelete: Cascade)
  raceId           String
  eventId          String
  athlete          AthleteProfile? @relation(fields: [athleteId], references: [id])
  athleteId        String?
  societyId        String?
  formData         Json
  pricePaid        Float
  discountCode     String?
  paymentMethod    String?
  paymentStatus    PaymentStatus   @default(PENDING)
  assignedCategory String?
  fidalVerified    Boolean         @default(false)
  addedByOrganizer Boolean         @default(false)
  certStatus       CertStatus?
  submittedAt      DateTime        @default(now())

  @@index([raceId])
  @@index([eventId])
  @@index([societyId])
}

// Dataset FIDAL importato (lookup interno, no API esterna).
model FidalAthlete {
  tessera       String    @id
  tipo          String
  nome          String
  cognome       String
  dataNascita   DateTime?
  sesso         String
  societa       String
  codiceSocieta String
  certScadenza  DateTime?

  @@index([codiceSocieta])
}

model ResultUpload {
  id            String      @id @default(cuid())
  raceId        String
  fileName      String
  columnMapping Json
  uploadedAt    DateTime    @default(now())
  rows          ResultRow[]
}

model ResultRow {
  id       String       @id @default(cuid())
  upload   ResultUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  uploadId String
  race     Race?        @relation(fields: [raceId], references: [id])
  raceId   String?
  section  String?
  position Int
  data     Json

  @@index([raceId])
}
